---
import Sidebar from '@components/Sidebar.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Authentic Ayurveda education, consultations, and seminars. Based in Osaka, Japan.' } = Astro.props;
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title} | e-Ayurveda Osaka</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link
    href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&family=Crimson+Pro:ital,wght@0,300;0,400;0,600;1,300;1,400&display=swap"
    rel="stylesheet"
  />
</head>
<body>
  <button class="mobile-nav-toggle" id="nav-toggle">☰ &nbsp;e-Ayurveda</button>

  <div class="site-wrapper">
    <Sidebar currentPath={Astro.url.pathname} />

    <main class="main-content">
      <slot />

      <footer>
        <div class="footer-brand">
          <div class="brand-name">e-Ayurveda &nbsp;·&nbsp; アーユルヴェーダ大阪</div>
          <p>Copyright © 2004–2025 e-ayurveda.com. All rights reserved.</p>
        </div>
        <div class="footer-links">
          <a href="/news">News</a>
          <a href="/about">About</a>
          <a href="/courses">Courses</a>
          <a href="/seminars">Seminars</a>
          <a href="/consultation">Consultation</a>
          <a href="/blog">Blog</a>
          <a href="/india">India Tours</a>
          <a href="/contact">Contact</a>
        </div>
      </footer>
    </main>
  </div>

  <script>
    document.getElementById('nav-toggle')?.addEventListener('click', () => {
      document.getElementById('sidebar')?.classList.toggle('open');
    });
  </script>
</body>
</html>

<style>
  footer {
    background: var(--green-deep);
    padding: 36px 40px;
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 24px;
    align-items: center;
  }
  .footer-brand .brand-name {
    font-family: 'Cormorant Garamond', serif;
    font-size: 20px;
    font-weight: 300;
    color: var(--white);
    letter-spacing: 2px;
  }
  .footer-brand p {
    font-size: 13px;
    color: rgba(255,255,255,0.45);
    margin-top: 6px;
  }
  .footer-links {
    display: flex;
    gap: 20px;
    flex-wrap: wrap;
  }
  .footer-links a {
    font-size: 13px;
    color: rgba(255,255,255,0.5);
    text-decoration: none;
    letter-spacing: 0.5px;
    transition: color 0.2s;
  }
  .footer-links a:hover { color: var(--gold-light); }

  @media (max-width: 820px) {
    footer { grid-template-columns: 1fr; padding: 28px 20px; }
  }
</style>
