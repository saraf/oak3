---
interface Props {
  title: string;
  titleEm?: string;
  subtitle: string;
}
const { title, titleEm, subtitle } = Astro.props;
---

<div class="top-banner">
  <div class="banner-text">
    <h1>{title}{titleEm && <> <em>{titleEm}</em></>}</h1>
    <p>{subtitle}</p>
  </div>
  <div class="banner-emblem">
    <svg width="90" height="90" viewBox="0 0 90 90" fill="none">
      <circle cx="45" cy="45" r="42" stroke="#c4963a" stroke-width="1" stroke-dasharray="4 3"/>
      <circle cx="45" cy="45" r="30" stroke="#c4963a" stroke-width="0.5" opacity="0.5"/>
      <text x="45" y="52" text-anchor="middle" font-family="serif" font-size="28" fill="#c8a96e" opacity="0.8">☽</text>
      <text x="45" y="72" text-anchor="middle" font-family="serif" font-size="9" fill="rgba(200,169,110,0.5)" letter-spacing="2">AYURVEDA</text>
    </svg>
  </div>
</div>

<style>
  .top-banner {
    background: linear-gradient(135deg, var(--green-deep) 0%, var(--green-mid) 50%, #3d6b50 100%);
    padding: 0 40px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    min-height: 120px;
    position: relative;
    overflow: hidden;
  }
  .top-banner::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image:
      radial-gradient(ellipse at 80% 50%, rgba(196,150,58,0.12) 0%, transparent 60%),
      url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23c4963a' fill-opacity='0.04'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
  }
  .banner-text { position: relative; }
  .banner-text h1 {
    font-family: 'Cormorant Garamond', serif;
    font-size: 36px;
    font-weight: 300;
    color: var(--white);
    letter-spacing: 2px;
    line-height: 1.2;
  }
  .banner-text h1 em { font-style: italic; color: var(--gold-light); }
  .banner-text p {
    font-size: 13px;
    color: rgba(255,255,255,0.6);
    letter-spacing: 2px;
    text-transform: uppercase;
    margin-top: 6px;
    font-weight: 300;
  }
  .banner-emblem {
    width: 90px;
    height: 90px;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }
  .banner-emblem svg { opacity: 0.6; }

  @media (max-width: 820px) {
    .top-banner { padding: 24px 20px; min-height: auto; }
    .banner-text h1 { font-size: 26px; }
    .banner-emblem { display: none; }
  }
</style>
