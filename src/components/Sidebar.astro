---
interface Props {
  currentPath: string;
}
const { currentPath } = Astro.props;

const isActive = (href: string) =>
  currentPath === href || (href !== '/' && currentPath.startsWith(href));

const navItems = [
  { href: '/news',         label: "What's New" },
  { href: '/about',        label: 'About Ayurveda' },
  { section: 'Learn' },
  { href: '/courses',      label: 'Courses & Lectures' },
  { href: '/seminars',     label: 'Seminars' },
  { href: '/consultation', label: 'Consultation' },
  { section: 'Explore' },
  { href: '/blog',         label: 'Blog & Articles' },
  { href: '/india',        label: 'India Culture' },
  { href: '/gallery',        label: 'Gallery' },
  { section: 'Connect' },
  { href: '/contact',      label: 'Contact' },
];
---

<aside class="sidebar" id="sidebar">
  <div class="sidebar-logo">
    <span class="logo-sanskrit">आयुर्वेद</span>
    <a href="/" class="logo-main">e-Ayurveda</a>
    <span class="logo-sub">Osaka, Japan</span>
  </div>

  <nav class="sidebar-nav">
    {navItems.map(item =>
      'section' in item
        ? <div class="nav-section">{item.section}</div>
        : <a href={item.href} class={isActive(item.href!) ? 'active' : ''}>
            ▸ &nbsp;{item.label}
          </a>
    )}
  </nav>

  <div class="sidebar-footer">
    Copyright © 2004–2025<br />e-ayurveda.com
  </div>
</aside>

<style>
  .sidebar {
    width: 210px;
    min-width: 210px;
    background: var(--green-deep);
    display: flex;
    flex-direction: column;
    position: sticky;
    top: 0;
    height: 100vh;
    overflow-y: auto;
  }

  .sidebar-logo {
    padding: 28px 20px 22px;
    border-bottom: 1px solid rgba(196,150,58,0.35);
    text-align: center;
  }
  .logo-sanskrit {
    font-family: 'Cormorant Garamond', serif;
    font-size: 11px;
    font-weight: 300;
    letter-spacing: 3px;
    color: var(--gold-light);
    text-transform: uppercase;
    display: block;
    margin-bottom: 6px;
  }
  .logo-main {
    font-family: 'Cormorant Garamond', serif;
    font-size: 22px;
    font-weight: 600;
    color: var(--white);
    letter-spacing: 1px;
    line-height: 1.2;
    text-decoration: none;
    display: block;
  }
  .logo-sub {
    font-family: 'Crimson Pro', serif;
    font-size: 12px;
    font-weight: 300;
    color: rgba(255,255,255,0.55);
    letter-spacing: 1.5px;
    margin-top: 4px;
    display: block;
  }

  .sidebar-nav {
    padding: 12px 0 20px;
    flex: 1;
  }
  .sidebar-nav a {
    display: block;
    padding: 9px 22px;
    color: rgba(255,255,255,0.78);
    text-decoration: none;
    font-family: 'Crimson Pro', serif;
    font-size: 14.5px;
    font-weight: 400;
    letter-spacing: 0.5px;
    transition: all 0.2s ease;
    border-left: 3px solid transparent;
  }
  .sidebar-nav a:hover,
  .sidebar-nav a.active {
    color: var(--gold-light);
    border-left-color: var(--gold);
    background: rgba(196,150,58,0.1);
    padding-left: 26px;
  }
  .nav-section {
    font-size: 10px;
    letter-spacing: 2.5px;
    color: rgba(255,255,255,0.3);
    text-transform: uppercase;
    padding: 14px 22px 4px;
    font-family: 'Crimson Pro', serif;
    font-weight: 300;
  }

  .sidebar-footer {
    padding: 16px 20px;
    border-top: 1px solid rgba(196,150,58,0.25);
    font-size: 11px;
    color: rgba(255,255,255,0.3);
    text-align: center;
    font-family: 'Crimson Pro', serif;
  }

  @media (max-width: 820px) {
    .sidebar {
      position: fixed;
      top: 48px; left: 0; bottom: 0;
      z-index: 99;
      transform: translateX(-100%);
      transition: transform 0.3s ease;
      height: calc(100vh - 48px);
      width: 240px;
      min-width: 0;
    }
    .sidebar.open { transform: translateX(0); }
  }
</style>
