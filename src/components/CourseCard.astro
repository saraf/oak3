---
import type { CollectionEntry } from 'astro:content';

interface Props {
  course: CollectionEntry<'courses'>;
}

const { course } = Astro.props;
const c = course.data;

const statusClass = { open: 'open', full: 'full', enquire: 'soon' }[c.status];
const statusText  = { open: 'Open', full: 'Full', enquire: 'Enquire' }[c.status];
---

<div class="course-card">
  <div class="card-top">
    <span class={`status ${statusClass}`}>{statusText}</span>
  </div>
  <h3>{c.title}</h3>
  {c.subtitle && <p class="subtitle">{c.subtitle}</p>}
  <div class="course-meta">
    <span>📅 {c.schedule}</span>
    <span>⏱ {c.duration}</span>
    <span>📍 {c.location}</span>
  </div>
  {c.syllabus && c.syllabus.length > 0 && (
    <ul class="syllabus-preview">
      {c.syllabus.slice(0, 3).map(item => <li>{item}</li>)}
      {c.syllabus.length > 3 && (
        <li class="more">+ {c.syllabus.length - 3} more topics</li>
      )}
    </ul>
  )}
  <a href={`/courses/${course.slug}`} class="btn btn-primary card-btn">View Course →</a>
</div>

<style>
  .course-card {
    border: 1px solid var(--border);
    padding: 24px;
    background: var(--white);
    transition: all 0.25s ease;
    position: relative;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .course-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 3px;
    background: linear-gradient(to right, var(--green-deep), var(--gold));
  }
  .course-card:hover {
    box-shadow: 0 8px 32px rgba(28,53,38,0.12);
    transform: translateY(-2px);
  }
  .card-top {
    display: flex;
    justify-content: flex-end;
  }
  .course-card h3 {
    font-family: 'Cormorant Garamond', serif;
    font-size: 20px;
    font-weight: 500;
    color: var(--green-deep);
    line-height: 1.3;
  }
  .subtitle {
    font-size: 14px;
    color: var(--text-light);
    font-style: italic;
  }
  .course-meta {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .course-meta span {
    font-size: 13px;
    color: var(--text-light);
  }
  .syllabus-preview {
    list-style: none;
    padding: 0;
    margin: 0;
    border-top: 1px solid var(--border);
    padding-top: 10px;
    flex: 1;
  }
  .syllabus-preview li {
    font-size: 13.5px;
    color: var(--text-light);
    padding: 3px 0 3px 16px;
    position: relative;
    line-height: 1.4;
  }
  .syllabus-preview li::before {
    content: '✦';
    position: absolute;
    left: 0;
    color: var(--gold);
    font-size: 9px;
    top: 7px;
  }
  .syllabus-preview li.more {
    color: var(--green-light);
    font-style: italic;
    font-size: 13px;
  }
  .syllabus-preview li.more::before { display: none; }
  .card-btn { margin-top: auto; align-self: flex-start; }
</style>
