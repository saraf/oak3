---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Banner from '../../components/Banner.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import { getCollection } from 'astro:content';

const allEntries = await getCollection('gallery');

// Sort newest first
const entries = allEntries.sort((a, b) =>
  new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);

const categoryLabel: Record<string, string> = {
  seminar:  'Seminar',
  india:    'India Tour',
  workshop: 'Workshop',
  cultural: 'Cultural',
};
---

<BaseLayout
  title="Photo Gallery"
  description="Photo reports from Ayurveda seminars, India study tours, workshops, and events at the Osaka Ayurveda Institute."
>
  <Banner title="Photo" titleEm="Gallery" subtitle="Seminars · India Tours · Workshops" />

  <section class="bg-white gallery-section">
    <SectionHeader title="Event Photo Reports" jp="写真集" />

    <!-- FILTER BUTTONS -->
    <div class="filter-bar" id="filterBar">
      <button class="filter-btn active" data-filter="all">All</button>
      <button class="filter-btn" data-filter="seminar">Seminars</button>
      <button class="filter-btn" data-filter="india">India Tours</button>
      <button class="filter-btn" data-filter="workshop">Workshops</button>
      <button class="filter-btn" data-filter="cultural">Cultural</button>
    </div>

    <!-- GALLERY GRID -->
    <div class="gallery-grid" id="galleryGrid">
      {entries.map(entry => {
        const e = entry.data;
        const photoCount = e.images.length;
        const cover = e.coverImage ?? e.images[0]?.file;
        return (
          <a
            href={`/gallery/${entry.slug}`}
            class="gallery-card"
            data-category={e.category}
          >
            <div class="card-image">
              {cover
                ? <img src={cover} alt={e.title} loading="lazy" />
                : <div class="card-placeholder">🌿</div>
              }
              <div class="card-overlay">
                <span class="photo-count">📷 {photoCount} photo{photoCount !== 1 ? 's' : ''}</span>
              </div>
              <span class={`category-badge cat-${e.category}`}>
                {categoryLabel[e.category]}
              </span>
            </div>
            <div class="card-body">
              <p class="card-date">{new Date(e.date).toLocaleDateString('en-GB', { year: 'numeric', month: 'long' })}</p>
              <h3 class="card-title">{e.title}</h3>
              <p class="card-desc">{e.description}</p>
            </div>
          </a>
        );
      })}
    </div>

    <!-- EMPTY STATE -->
    <p class="no-results" id="noResults" style="display:none">
      No entries in this category yet.
    </p>
  </section>
</BaseLayout>

<script>
  const btns   = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
  const cards  = document.querySelectorAll<HTMLElement>('.gallery-card');
  const noResults = document.getElementById('noResults')!;

  btns.forEach(btn => {
    btn.addEventListener('click', () => {
      const filter = btn.dataset.filter!;

      // Update active button
      btns.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');

      // Show/hide cards
      let visible = 0;
      cards.forEach(card => {
        const match = filter === 'all' || card.dataset.category === filter;
        card.style.display = match ? '' : 'none';
        if (match) visible++;
      });

      noResults.style.display = visible === 0 ? 'block' : 'none';
    });
  });
</script>

<style>
  .gallery-section { padding-bottom: 60px; }

  /* ── FILTER BAR ── */
  .filter-bar {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 36px;
  }
  .filter-btn {
    padding: 7px 18px;
    border: 1px solid var(--border);
    background: transparent;
    color: var(--text-light);
    font-family: 'Crimson Pro', serif;
    font-size: 14px;
    letter-spacing: 1px;
    cursor: pointer;
    transition: all 0.2s;
  }
  .filter-btn:hover {
    border-color: var(--green-mid);
    color: var(--green-mid);
  }
  .filter-btn.active {
    background: var(--green-deep);
    border-color: var(--green-deep);
    color: var(--gold-light);
  }

  /* ── GRID ── */
  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }

  /* ── CARD ── */
  .gallery-card {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    border: 1px solid var(--border);
    overflow: hidden;
    transition: all 0.25s ease;
    background: white;
  }
  .gallery-card:hover {
    box-shadow: 0 8px 32px rgba(28,53,38,0.12);
    transform: translateY(-3px);
  }

  .card-image {
    position: relative;
    aspect-ratio: 4 / 3;
    overflow: hidden;
    background: var(--cream);
  }
  .card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }
  .gallery-card:hover .card-image img {
    transform: scale(1.04);
  }
  .card-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 48px;
    background: linear-gradient(135deg, var(--green-deep), #3d6b50);
  }
  .card-overlay {
    position: absolute;
    bottom: 0; left: 0; right: 0;
    padding: 8px 12px;
    background: linear-gradient(to top, rgba(0,0,0,0.55), transparent);
    opacity: 0;
    transition: opacity 0.2s;
  }
  .gallery-card:hover .card-overlay { opacity: 1; }
  .photo-count {
    color: white;
    font-size: 12px;
    letter-spacing: 0.5px;
  }

  .category-badge {
    position: absolute;
    top: 10px; left: 10px;
    padding: 3px 10px;
    font-size: 11px;
    letter-spacing: 1px;
    text-transform: uppercase;
    font-family: 'Crimson Pro', serif;
  }
  .cat-seminar  { background: var(--green-deep); color: var(--gold-light); }
  .cat-india    { background: #8b4513; color: #fdf0e0; }
  .cat-workshop { background: #2c5f6e; color: #e8f4f8; }
  .cat-cultural { background: #5c3566; color: #f5e8f8; }

  .card-body {
    padding: 18px 20px 20px;
    display: flex;
    flex-direction: column;
    gap: 6px;
    flex: 1;
  }
  .card-date {
    font-size: 12px;
    color: var(--text-light);
    letter-spacing: 1px;
    text-transform: uppercase;
    font-family: 'Crimson Pro', serif;
  }
  .card-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: 18px;
    font-weight: 500;
    color: var(--green-deep);
    line-height: 1.3;
  }
  .card-desc {
    font-size: 13.5px;
    color: var(--text-light);
    line-height: 1.6;
  }

  .no-results {
    text-align: center;
    color: var(--text-light);
    font-style: italic;
    padding: 40px 0;
  }

  /* ── RESPONSIVE ── */
  @media (max-width: 960px) {
    .gallery-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 600px) {
    .gallery-grid { grid-template-columns: 1fr; }
  }
</style>
