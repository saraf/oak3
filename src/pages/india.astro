---
import BaseLayout from '../layouts/BaseLayout.astro';
import Banner from '../components/Banner.astro';
import SectionHeader from '../components/SectionHeader.astro';
---

<BaseLayout title="India Culture & Study Tours" description="Ayurveda study tours to Kerala, India and Indian cultural events in Osaka.">
  <Banner
    title="India Culture &"
    titleEm="Study Tours"
    subtitle="Kerala · Cultural events · Immersive learning"
  />

  <section class="bg-cream">
    <SectionHeader title="India Culture & Study Tours" jp="インド文化・ツアー" />
    <div class="india-layout">
      <div>
        <p>
          Ayurveda cannot be fully understood without experiencing India — its seasons, its smells,
          its rhythms. Each year we organise small-group study tours to Kerala and other Ayurvedic
          heartlands, where participants receive authentic treatments, study with Indian
          practitioners, and immerse themselves in the living tradition.
        </p>
        <p>
          We also host regular cultural events in Osaka celebrating Indian arts, music, cuisine,
          and philosophy — because understanding the culture is inseparable from understanding
          the medicine.
        </p>
        <p>
          <a href="/contact" class="btn btn-primary">Ask about 2026 India Tour</a>
        </p>
      </div>
      <div class="tour-card">
        <h3>Kerala 2026 Tour</h3>
        <ul>
          <li>📅 &nbsp;March 2026 (10 nights)</li>
          <li>✈️ &nbsp;Depart from Osaka/Kansai</li>
          <li>🏡 &nbsp;Authentic Ayurveda resort stay</li>
          <li>💆 &nbsp;Daily treatments included</li>
          <li>👩‍⚕️ &nbsp;Consultations with vaidyas</li>
          <li>👥 &nbsp;Max 8 participants</li>
        </ul>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .india-layout {
    display: grid;
    grid-template-columns: 2fr 1fr;
    gap: 36px;
    align-items: start;
  }
  p { margin-bottom: 14px; font-size: 16.5px; }
  .tour-card {
    background: var(--green-deep);
    padding: 24px;
    color: var(--white);
  }
  .tour-card h3 {
    font-family: 'Cormorant Garamond', serif;
    font-size: 17px;
    color: var(--gold-light);
    margin-bottom: 14px;
    font-weight: 400;
  }
  .tour-card ul { list-style: none; font-size: 14px; line-height: 2; }
  @media (max-width: 820px) {
    .india-layout { grid-template-columns: 1fr; }
  }
</style>
