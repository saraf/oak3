---
import BaseLayout from '../layouts/BaseLayout.astro';
import Banner from '../components/Banner.astro';
import SectionHeader from '../components/SectionHeader.astro';

const courses = [
  {
    title: 'Ayurveda Fundamentals',
    schedule: 'Monthly start',
    duration: '8 sessions',
    location: 'Osaka / Online',
    description:
      'A thorough introduction to Ayurvedic philosophy, the five elements, the three doshas, and daily wellness practices. Perfect for beginners and health-conscious individuals.',
  },
  {
    title: 'Practitioner Certificate Course',
    schedule: 'Twice yearly',
    duration: '24 sessions',
    location: 'Osaka',
    description:
      'A comprehensive professional-level program covering Ayurvedic diagnosis, herbal medicine, lifestyle counselling, and hands-on treatment techniques.',
  },
  {
    title: 'Ayurvedic Cooking Workshop',
    schedule: 'Seasonal',
    duration: '1–3 sessions',
    location: 'Osaka',
    description:
      'Learn to prepare nourishing Ayurvedic meals using seasonal Japanese and Indian ingredients. Includes spice blending, medicinal teas, and dosha-specific meal planning.',
  },
  {
    title: 'Self-Care & Daily Routine',
    schedule: 'On demand',
    duration: '4 sessions',
    location: 'Online',
    description:
      'Establish a sustainable Dinacharya (daily routine) rooted in Ayurvedic wisdom. Covers sleep, oil massage, tongue scraping, yoga integration, and seasonal adjustments.',
  },
];
---

<BaseLayout title="Courses & Lectures" description="Ayurveda courses and lectures in Osaka and online. From beginner fundamentals to practitioner certification.">
  <Banner
    title="Courses &"
    titleEm="Lectures"
    subtitle="Fundamentals · Certification · Workshops"
  />

  <section class="bg-white">
    <SectionHeader title="Courses & Lectures" jp="講座・コース" />
    <div class="courses-grid">
      {courses.map(course => (
        <div class="course-card">
          <h3>{course.title}</h3>
          <div class="course-meta">
            <span>📅 {course.schedule}</span>
            <span>⏱ {course.duration}</span>
            <span>📍 {course.location}</span>
          </div>
          <p>{course.description}</p>
          <a href="/contact" class="btn btn-primary">Enquire →</a>
        </div>
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  .courses-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
  }
  .course-card {
    border: 1px solid var(--border);
    padding: 24px;
    background: var(--white);
    transition: all 0.25s ease;
    position: relative;
    overflow: hidden;
  }
  .course-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 3px;
    background: linear-gradient(to right, var(--green-deep), var(--gold));
  }
  .course-card:hover {
    box-shadow: 0 8px 32px rgba(28,53,38,0.12);
    transform: translateY(-2px);
  }
  .course-card h3 {
    font-family: 'Cormorant Garamond', serif;
    font-size: 20px;
    font-weight: 500;
    color: var(--green-deep);
    margin-bottom: 8px;
  }
  .course-meta {
    display: flex;
    gap: 12px;
    margin-bottom: 12px;
    flex-wrap: wrap;
  }
  .course-meta span {
    font-size: 12px;
    color: var(--text-light);
    letter-spacing: 0.5px;
  }
  .course-card p {
    font-size: 15px;
    color: var(--text-light);
    margin-bottom: 16px;
    line-height: 1.6;
  }
  @media (max-width: 820px) {
    .courses-grid { grid-template-columns: 1fr; }
  }
</style>
