---
import BaseLayout from '../layouts/BaseLayout.astro';
import Banner from '../components/Banner.astro';
import SectionHeader from '../components/SectionHeader.astro';
---

<BaseLayout title="Contact" description="Contact e-Ayurveda Osaka — enquire about courses, seminars, consultation, or the India study tour.">
  <Banner
    title="Contact"
    titleEm="Us"
    subtitle="Enquiries · Bookings · Information"
  />

  <section class="bg-cream">
    <SectionHeader title="Contact Us" jp="お問い合わせ" />
    <div class="contact-layout">
      <div class="contact-details">
        <h3>Get in Touch</h3>
        <div class="detail-item">
          <div class="d-label">Location</div>
          Osaka, Japan
        </div>
        <div class="detail-item">
          <div class="d-label">Email</div>
          <a href="mailto:info@e-ayurveda.com">info@e-ayurveda.com</a>
        </div>
        <div class="detail-item">
          <div class="d-label">Languages</div>
          English · Japanese
        </div>
        <div class="detail-item">
          <div class="d-label">Response time</div>
          Within 2 business days
        </div>
        <div class="detail-item">
          <div class="d-label">Japanese site</div>
          <a href="https://www.e-ayurveda.com" target="_blank" rel="noopener">e-ayurveda.com</a>
        </div>
        <p class="contact-note">
          We welcome enquiries about courses, seminars, consultations, and India tours.
          Please include your preferred language and any relevant health context.
        </p>
      </div>

      <div class="form-card">
        <h3>Send a Message</h3>
        <div class="form-grid">
          <div class="form-row">
            <label>Name <span class="required">*</span></label>
            <input type="text" placeholder="Your name" id="contact-name" />
          </div>
          <div class="form-row">
            <label>Email <span class="required">*</span></label>
            <input type="email" placeholder="your@email.com" id="contact-email" />
          </div>
        </div>
        <div class="form-row">
          <label>Subject</label>
          <select id="contact-subject">
            <option>General Enquiry</option>
            <option>Course Information</option>
            <option>Seminar Registration</option>
            <option>Consultation Booking</option>
            <option>India Tour</option>
            <option>Other</option>
          </select>
        </div>
        <div class="form-row">
          <label>Message <span class="required">*</span></label>
          <textarea id="contact-msg" placeholder="How can we help you?" style="min-height:120px;"></textarea>
        </div>
        <div class="form-submit-row">
          <button class="btn btn-gold" id="contact-btn">Send Message</button>
        </div>
        <div class="success-msg" id="contact-success">
          Thank you for your message. We will be in touch within 2 business days.
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .contact-layout {
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: 40px;
  }
  .contact-details h3 {
    font-family: 'Cormorant Garamond', serif;
    font-size: 20px;
    color: var(--green-deep);
    margin-bottom: 16px;
    font-weight: 400;
  }
  .detail-item {
    padding: 10px 0;
    border-bottom: 1px solid var(--border);
    font-size: 15px;
  }
  .d-label {
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    color: var(--text-light);
    margin-bottom: 3px;
  }
  .detail-item a { color: var(--green-mid); text-decoration: none; }
  .detail-item a:hover { text-decoration: underline; }
  .contact-note {
    margin-top: 20px;
    font-size: 14px;
    color: var(--text-light);
    line-height: 1.7;
  }
  @media (max-width: 820px) {
    .contact-layout { grid-template-columns: 1fr; }
  }
</style>

<script>
  document.getElementById('contact-btn')?.addEventListener('click', () => {
    const name = (document.getElementById('contact-name') as HTMLInputElement)?.value.trim();
    const email = (document.getElementById('contact-email') as HTMLInputElement)?.value.trim();
    const msg = (document.getElementById('contact-msg') as HTMLTextAreaElement)?.value.trim();
    if (!name || !email || !msg) { alert('Please fill in all required fields.'); return; }
    const success = document.getElementById('contact-success');
    const btn = document.getElementById('contact-btn') as HTMLButtonElement;
    if (success) success.style.display = 'block';
    if (btn) { btn.disabled = true; btn.textContent = 'Message Sent ✓'; btn.style.background = '#4a7c5e'; }
  });
</script>
