---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Banner from '../../components/Banner.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const seminars = await getCollection('seminars');
  return seminars.map(seminar => ({
    params: { slug: seminar.slug },
    props:  { seminar },
  }));
}

const { seminar } = Astro.props;
const { Content } = await seminar.render();
const s = seminar.data;
---

<BaseLayout title={s.title} description={`${s.date} · ${s.format}`}>
  <Banner title={s.title} subtitle={`${s.date} · ${s.format}`} />

  <article class="seminar-detail bg-white">

    <!-- META BAR -->
    <div class="meta-bar">
      <span class={`status ${s.status}`}>{s.status}</span>
      <span>📅 {s.date}</span>
      <span>📍 {s.format}</span>
      {s.capacity && <span>👥 {s.capacity}</span>}
      {s.deadline && <span>⏰ Register by {s.deadline}</span>}
    </div>

    <div class="seminar-layout">

      <!-- MAIN BODY -->
      <div class="seminar-body">

        <!-- FLYER IMAGES -->
        {s.images && s.images.length > 0 && (
          <div class="flyer-images">
            {s.images.map(img => (
              <img src={img} alt="Seminar flyer" class="flyer-img" />
            ))}
          </div>
        )}

        <!-- PDF DOWNLOADS -->
        {s.pdfs && s.pdfs.length > 0 && (
          <div class="pdf-downloads">
            <h4>Downloads</h4>
            {s.pdfs.map(pdf => (
              <a href={pdf.file} class="pdf-link" download>
                <span class="pdf-icon">📄</span>
                {pdf.label}
              </a>
            ))}
          </div>
        )}

        <!-- RICH MARKDOWN BODY -->
        <div class="seminar-content">
          <Content />
        </div>

      </div>

      <!-- SIDEBAR -->
      <aside class="seminar-sidebar">

        <!-- FEE -->
        {s.fee && (
          <div class="info-card">
            <h3>Fee</h3>
            <p>{s.fee}</p>
          </div>
        )}

        <!-- VENUE -->
        {s.venue && (
          <div class="info-card">
            <h3>Venue</h3>
            <p class="venue-name">{s.venue.name}</p>
            {s.venue.address && <p class="venue-address">{s.venue.address}</p>}
            {s.venue.access && (
              <p class="venue-access">🚇 {s.venue.access}</p>
            )}
          </div>
        )}

        <!-- SPEAKERS -->
        {s.speakers && s.speakers.length > 0 && (
          <div class="info-card">
            <h3>{s.speakers.length === 1 ? 'Speaker' : 'Speakers'}</h3>
            {s.speakers.map(speaker => (
              <div class="speaker">
                <strong class="speaker-name">{speaker.name}</strong>
                {speaker.title && <p class="speaker-title">{speaker.title}</p>}
                {speaker.bio   && <p class="speaker-bio">{speaker.bio}</p>}
              </div>
            ))}
          </div>
        )}

        <!-- REGISTER CTA -->
        <div class="info-card register-card">
          <h3>Register</h3>
          {s.deadline && <p class="deadline-note">Registration deadline:<br /><strong>{s.deadline}</strong></p>}
          <a href="/contact" class="btn btn-gold register-btn">
            Enquire / Register →
          </a>
          <a href="/seminars" class="back-link">← All seminars</a>
        </div>

      </aside>
    </div>
  </article>
</BaseLayout>

<style>
  .seminar-detail {
    padding: 0;
  }

  /* ── META BAR ── */
  .meta-bar {
    display: flex;
    flex-wrap: wrap;
    gap: 18px;
    align-items: center;
    padding: 16px 40px;
    background: var(--cream);
    border-bottom: 1px solid var(--border);
    font-size: 14px;
    color: var(--text-light);
  }
  .meta-bar .status {
    font-size: 11px;
    padding: 3px 10px;
    border-radius: 2px;
    letter-spacing: 1px;
    text-transform: uppercase;
  }

  /* ── TWO-COLUMN LAYOUT ── */
  .seminar-layout {
    display: grid;
    grid-template-columns: 1fr 280px;
    gap: 0;
    align-items: start;
  }

  /* ── MAIN BODY ── */
  .seminar-body {
    padding: 44px 40px;
    border-right: 1px solid var(--border);
  }

  /* FLYER IMAGES */
  .flyer-images {
    margin-bottom: 28px;
    display: flex;
    flex-wrap: wrap;
    gap: 16px;
  }
  .flyer-img {
    max-width: 100%;
    max-height: 400px;
    object-fit: contain;
    border: 1px solid var(--border);
  }

  /* PDF DOWNLOADS */
  .pdf-downloads {
    margin-bottom: 28px;
    padding: 16px 20px;
    background: var(--cream);
    border: 1px solid var(--border);
  }
  .pdf-downloads h4 {
    font-family: 'Cormorant Garamond', serif;
    font-size: 13px;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    color: var(--text-light);
    margin-bottom: 10px;
  }
  .pdf-link {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 8px 0;
    color: var(--green-mid);
    text-decoration: none;
    font-size: 15px;
    border-bottom: 1px dashed var(--border);
    transition: color 0.2s;
  }
  .pdf-link:last-child { border-bottom: none; }
  .pdf-link:hover { color: var(--green-deep); }
  .pdf-icon { font-size: 18px; }

  /* RICH CONTENT */
  .seminar-content {
    font-size: 17px;
    line-height: 1.8;
    color: var(--text);
  }
  .seminar-content h2 {
    font-family: 'Cormorant Garamond', serif;
    font-size: 24px;
    font-weight: 500;
    color: var(--green-deep);
    margin: 36px 0 14px;
    padding-bottom: 8px;
    border-bottom: 1px solid var(--border);
  }
  .seminar-content h3 {
    font-family: 'Cormorant Garamond', serif;
    font-size: 20px;
    color: var(--green-mid);
    margin: 24px 0 8px;
  }
  .seminar-content p { margin-bottom: 14px; }
  .seminar-content ul,
  .seminar-content ol { margin: 10px 0 18px 24px; }
  .seminar-content li { margin-bottom: 5px; }
  .seminar-content strong { color: var(--text); font-weight: 600; }
  .seminar-content em { font-style: italic; color: var(--green-mid); }
  .seminar-content table {
    width: 100%;
    border-collapse: collapse;
    margin: 18px 0 24px;
    font-size: 15px;
  }
  .seminar-content table th {
    background: var(--green-deep);
    color: var(--gold-light);
    padding: 8px 12px;
    text-align: left;
    font-family: 'Crimson Pro', serif;
    font-weight: 400;
    letter-spacing: 1px;
    font-size: 13px;
  }
  .seminar-content table td {
    padding: 10px 12px;
    border-bottom: 1px solid var(--border);
    vertical-align: top;
  }
  .seminar-content table tr:last-child td { border-bottom: none; }
  .seminar-content table tr:hover td { background: rgba(196,150,58,0.04); }

  /* ── SIDEBAR ── */
  .seminar-sidebar {
    padding: 32px 24px;
    display: flex;
    flex-direction: column;
    gap: 20px;
    position: sticky;
    top: 0;
  }

  .info-card {
    background: var(--cream);
    border: 1px solid var(--border);
    padding: 18px 20px;
  }
  .info-card h3 {
    font-family: 'Cormorant Garamond', serif;
    font-size: 13px;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: var(--text-light);
    margin-bottom: 10px;
    padding-bottom: 8px;
    border-bottom: 1px solid var(--border);
  }
  .info-card p { font-size: 14.5px; color: var(--text); line-height: 1.6; margin-bottom: 6px; }
  .venue-name { font-weight: 600; color: var(--green-deep); }
  .venue-address { color: var(--text-light); font-size: 13.5px; }
  .venue-access { color: var(--text-light); font-size: 13px; margin-top: 8px; line-height: 1.5; }

  .speaker { margin-bottom: 14px; padding-bottom: 14px; border-bottom: 1px solid var(--border); }
  .speaker:last-child { border-bottom: none; margin-bottom: 0; padding-bottom: 0; }
  .speaker-name { font-size: 15px; color: var(--green-deep); display: block; margin-bottom: 3px; }
  .speaker-title { font-size: 12.5px; color: var(--gold); margin-bottom: 6px; }
  .speaker-bio { font-size: 13px; color: var(--text-light); line-height: 1.6; }

  .register-card { background: var(--green-deep); border-color: var(--green-deep); }
  .register-card h3 { color: var(--gold-light); border-bottom-color: rgba(196,150,58,0.3); }
  .register-card p.deadline-note {
    font-size: 13.5px;
    color: rgba(255,255,255,0.7);
    margin-bottom: 14px;
    line-height: 1.5;
  }
  .register-card p.deadline-note strong { color: var(--gold-light); }
  .register-btn {
    display: block;
    text-align: center;
    width: 100%;
    margin-bottom: 12px;
  }
  .back-link {
    display: block;
    text-align: center;
    font-size: 13px;
    color: rgba(255,255,255,0.45);
    text-decoration: none;
    letter-spacing: 0.5px;
    transition: color 0.2s;
  }
  .back-link:hover { color: var(--gold-light); }

  /* ── RESPONSIVE ── */
  @media (max-width: 820px) {
    .meta-bar { padding: 14px 20px; }
    .seminar-layout { grid-template-columns: 1fr; }
    .seminar-body { padding: 28px 20px; border-right: none; }
    .seminar-sidebar { padding: 0 20px 28px; position: static; }
  }
</style>
