---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Banner from '../../components/Banner.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import { getCollection } from 'astro:content';

const seminars = await getCollection('seminars');
---

<BaseLayout title="Seminars" description="Upcoming Ayurveda seminars in Osaka and online. Topics include detox, massage, herbs, skin rituals, and India study tours.">
  <Banner
    title="Upcoming"
    titleEm="Seminars"
    subtitle="Osaka · Online · India"
  />

  <section class="bg-white">
    <SectionHeader title="Upcoming Seminars" jp="セミナー案内" />
    <table class="seminar-table">
      <thead>
        <tr>
          <th>Date</th>
          <th>Title</th>
          <th>Format</th>
          <th>Capacity</th>
          <th>Status</th>
        </tr>
      </thead>
      <tbody>
        {seminars.map(s => (
          <tr>
            <td>{s.data.date}</td>
            <td>
              <a href={`/seminars/${s.slug}`}>{s.data.title}</a>
            </td>
            <td>{s.data.format}</td>
            <td>{s.data.capacity ?? '—'}</td>
            <td><span class={`status ${s.data.status}`}>{s.data.status}</span></td>
          </tr>
        ))}
      </tbody>
    </table>
    <p class="register-note">
      Click any seminar title for full details, programme, and registration.
      Or <a href="/contact">contact us</a> directly — we respond within 2 business days.
    </p>
  </section>
</BaseLayout>

<style>
  .seminar-table td a {
    color: var(--green-mid);
    text-decoration: none;
    font-weight: 500;
  }
  .seminar-table td a:hover {
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .register-note {
    margin-top: 20px;
    font-size: 14.5px;
    color: var(--text-light);
  }
  .register-note a { color: var(--green-mid); }
</style>
