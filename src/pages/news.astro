---
import BaseLayout from '../layouts/BaseLayout.astro';
import Banner from '../components/Banner.astro';
import SectionHeader from '../components/SectionHeader.astro';
import { getCollection } from 'astro:content';

const allNews = await getCollection('news');
// Sort by date descending
const news = allNews.sort((a, b) => b.data.date.localeCompare(a.data.date));
---

<BaseLayout title="What's New">
  <Banner
    title="What's"
    titleEm="New"
    subtitle="Latest news · seminars · articles"
  />

  <section class="bg-white">
    <SectionHeader title="What's New" jp="最新情報" />
    <div class="news-list">
      {news.map(item => (
        <div class="news-item">
          <span class="news-date">{item.data.date}</span>
          <span class={`news-tag ${item.data.tag}`}>{item.data.tag}</span>
          <div class="news-body">
            <a href={item.data.href ?? '#'}>{item.data.title}</a>
          </div>
        </div>
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  .news-list { display: flex; flex-direction: column; }
  .news-item {
    display: flex;
    gap: 24px;
    padding: 14px 0;
    border-bottom: 1px dashed var(--border);
    align-items: flex-start;
    transition: background 0.2s;
  }
  .news-item:last-child { border-bottom: none; }
  .news-item:hover {
    background: rgba(196,150,58,0.04);
    margin: 0 -8px;
    padding-left: 8px;
    padding-right: 8px;
  }
  .news-date {
    font-size: 12.5px;
    color: var(--text-light);
    min-width: 90px;
    padding-top: 2px;
    font-weight: 300;
    letter-spacing: 0.5px;
  }
  .news-tag {
    font-size: 10.5px;
    background: var(--green-deep);
    color: var(--gold-light);
    padding: 2px 8px;
    border-radius: 2px;
    letter-spacing: 1px;
    text-transform: uppercase;
    align-self: center;
    white-space: nowrap;
    font-family: 'Crimson Pro', serif;
  }
  .news-tag.seminar { background: var(--brown-mid); }
  .news-tag.blog { background: var(--green-light); }
  .news-body { flex: 1; }
  .news-body a {
    color: var(--text);
    text-decoration: none;
    font-size: 16px;
  }
  .news-body a:hover {
    color: var(--green-mid);
    text-decoration: underline;
    text-underline-offset: 3px;
  }
</style>
